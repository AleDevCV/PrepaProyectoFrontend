# ============================================================
#  Plantilla de variables de entorno — CONTIDELICIAS
#  Copia este archivo como ".env" y coloca tus valores reales.
#  (El .env real NO se sube a GitHub: está en .gitignore)
#
#  NOTA: El frontend estático actual NO necesita estas variables.
#  Solo aplican cuando se integre el Asistente Virtual con IA real
#  mediante un proceso de build o una función serverless.
# ============================================================

OPENAI_API_KEY=tu_clave_de_openai_aqui
OPENAI_MODEL=gpt-4o-mini
